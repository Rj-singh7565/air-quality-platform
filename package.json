{
  "name": "air-quality-platform",
  "version": "1.0.0",
  "description": "AI-Driven Hyperlocal Air Quality Monitoring and Citizen Accountability Platform",
  "private": true,
  "scripts": {
    "server": "python server/server.py",
    "server:dev": "python server/server.py",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "db:init": "python server/config/init_db.py"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
